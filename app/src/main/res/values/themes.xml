<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Alterado para .NoActionBar para evitar conflitos com a Toolbar manual nos layouts -->
    <style name="Theme.LeitorAcessivel" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Cores principais -->
        <item name="colorPrimary">#1565C0</item>
        <item name="colorPrimaryVariant">#0D47A1</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorSecondary">#00ACC1</item>
        <item name="colorSecondaryVariant">#00838F</item>
        <item name="colorOnSecondary">@android:color/black</item>

        <!-- Cores de superfície (Compatibilidade) -->
        <item name="colorOnSurface">@android:color/black</item>
        <item name="colorOnSurfaceVariant">#757575</item>

        <!-- Estas linhas reforçam a remoção -->
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <!-- Cor da barra de status (onde fica o relógio) -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>




    </style>
</resources>
